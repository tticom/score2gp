            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "techniques": {
          "items": {
            "discriminator": {
              "mapping": {
                "bend": "#/$defs/BendTechnique",
                "grace": "#/$defs/GraceTechnique",
                "hammer-on": "#/$defs/HammerOnTechnique",
                "let-ring": "#/$defs/LetRingTechnique",
                "palm-mute": "#/$defs/PalmMuteTechnique",
                "pull-off": "#/$defs/PullOffTechnique",
                "slide": "#/$defs/SlideTechnique",
                "slur": "#/$defs/SlurTechnique",
                "tie": "#/$defs/TieTechnique",
                "unsupported": "#/$defs/UnsupportedTechnique",
                "vibrato": "#/$defs/VibratoTechnique"
