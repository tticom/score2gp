          "type": "string"
        },
        "midi_channel": {
          "anyOf": [
            {
              "maximum": 16,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Midi Channel"
        },
        "midi_program": {
          "anyOf": [
            {
              "maximum": 127,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Midi Program"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "staff_count": {
          "default": 1,
          "maximum": 4,
          "minimum": 1,
