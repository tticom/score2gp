          "default": "unknown",
          "enum": [
            "slow",
            "medium",
            "fast",
            "unknown"
          ],
          "title": "Speed",
          "type": "string"
        },
        "width": {
          "default": "unknown",
          "enum": [
            "narrow",
            "wide",
            "unknown"
          ],
          "title": "Width",
          "type": "string"
        }
      },
      "title": "VibratoTechnique",
      "type": "object"
    },
    "WarningItem": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
