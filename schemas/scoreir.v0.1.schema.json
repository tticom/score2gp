          "type": "array"
        },
        "index": {
          "minimum": 1,
          "title": "Index",
          "type": "integer"
        },
        "key_signature": {
          "anyOf": [
            {
              "$ref": "#/$defs/KeySignature"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "time_signature": {
          "$ref": "#/$defs/TimeSignature"
        }
      },
      "required": [
        "index",
        "time_signature"
      ],
      "title": "Bar",
      "type": "object"
    },
    "BendPoint": {
      "additionalProperties": false,
      "properties": {
        "offset_ticks": {
          "minimum": 0,
          "title": "Offset Ticks",
          "type": "integer"
        },
