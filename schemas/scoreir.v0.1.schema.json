            "$ref": "#/$defs/BendPoint"
          },
          "title": "Points",
          "type": "array"
        },
        "semitones": {
          "anyOf": [
            {
              "maximum": 12.0,
              "minimum": -12.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Semitones"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        }
      },
      "title": "BendTechnique",
      "type": "object"
    },
    "BoundingBox": {
