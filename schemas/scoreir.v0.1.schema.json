        "normal_notes": {
          "exclusiveMinimum": 0,
          "maximum": 64,
          "title": "Normal Notes",
          "type": "integer"
        }
      },
      "required": [
        "actual_notes",
        "normal_notes"
      ],
      "title": "Tuplet",
      "type": "object"
