        },
        "number": {
          "maximum": 12,
          "minimum": 1,
          "title": "Number",
          "type": "integer"
        },
        "pitch": {
          "maximum": 127,
          "minimum": 0,
          "title": "Pitch",
          "type": "integer"
        }
      },
      "required": [
        "number",
        "pitch",
        "name"
      ],
      "title": "TuningString",
      "type": "object"
    },
    "Tuplet": {
      "additionalProperties": false,
      "properties": {
        "actual_notes": {
          "exclusiveMinimum": 0,
          "maximum": 64,
          "title": "Actual Notes",
          "type": "integer"
