        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "raw": {
          "additionalProperties": true,
          "title": "Raw",
          "type": "object"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
