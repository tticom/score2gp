            "oneOf": [
              {
                "$ref": "#/$defs/SlideTechnique"
              },
              {
                "$ref": "#/$defs/BendTechnique"
              },
              {
                "$ref": "#/$defs/VibratoTechnique"
              },
              {
                "$ref": "#/$defs/HammerOnTechnique"
              },
              {
                "$ref": "#/$defs/PullOffTechnique"
              },
              {
                "$ref": "#/$defs/TieTechnique"
              },
              {
                "$ref": "#/$defs/SlurTechnique"
              },
              {
                "$ref": "#/$defs/LetRingTechnique"
              },
              {
                "$ref": "#/$defs/PalmMuteTechnique"
              },
              {
                "$ref": "#/$defs/GraceTechnique"
