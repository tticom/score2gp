            "warning",
            "error"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "WarningItem",
      "type": "object"
    }
  },
  "$id": "https://github.com/tticom/score2gp/schemas/scoreir.v0.1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "bars": {
      "items": {
        "$ref": "#/$defs/Bar"
      },
      "title": "Bars",
      "type": "array"
    },
    "conversion": {
